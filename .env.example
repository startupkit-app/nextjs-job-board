# ── Required ─────────────────────────────────────────────────────────────────

# Secret API key (sk_…) — Kit → Hiring → Career Portal → Public API Keys.
# Used ONLY on the server (Server Components + Server Actions). Never exposed
# to the browser.
STARTUPKIT_SECRET_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Kit API base URL. Only change this if you run Kit on a custom domain.
STARTUPKIT_BASE_URL=https://app.startupkit.app

# Cloudflare Turnstile site key. If set, the apply form renders the Turnstile
# widget and forwards its token with each submission. Required when the job's
# application form has turnstile.required = true.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Shared secret for the POST /api/revalidate webhook endpoint. If set, you can
# point a Kit webhook (e.g. job_posting.published) at it to bust the cache
# instantly instead of waiting for ISR revalidation.
REVALIDATE_SECRET=

# Company name shown in the header, page titles, and schema.org JobPosting
# structured data.
NEXT_PUBLIC_COMPANY_NAME=
